			"class Kmp:",
			"    def __init__(self, pattern):",
			"        self.pattern = pattern",
			"        self.nxt = self.compute_nxt(pattern)",
			"",
			"    def compute_nxt(self, pattern):",
			"        \"\"\"Compute the prefix table (nxt) for KMP algorithm.\"\"\"",
			"        n = len(pattern)",
			"        nxt = Arr.array(0, n)",
			"        j = 0",
			"        for i in range(1, n):",
			"            while j > 0 and pattern[i] != pattern[j]:",
			"                j = nxt[j - 1]",
			"            if pattern[i] == pattern[j]:",
			"                j += 1",
			"            nxt[i] = j",
			"        return nxt",
			"",
			"    def search(self, text):",
			"        \"\"\"Search the pattern in the given text using KMP algorithm.\"\"\"",
			"        m = len(text)",
			"        n = len(self.pattern)",
			"        j = 0",
			"        result = []",
			"        for i in range(m):",
			"            while j > 0 and text[i] != self.pattern[j]:",
			"                j = self.nxt[j - 1]",
			"            if text[i] == self.pattern[j]:",
			"                j += 1",
			"            if j == n:",
			"                result.append(i - n + 1)",
			"                j = self.nxt[j - 1]",
			"        return result"
		],
